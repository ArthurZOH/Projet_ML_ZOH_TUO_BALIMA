# --- Environnements virtuels Python ---
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo

# --- Données volumineuses (ne jamais pousser le dataset Kaggle) ---
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# --- Comptes créés via l'inscription + clé des jetons de session ---
data/utilisateurs.json
data/.cle_session

# --- Modèles entraînés ---
# On ignore le dossier par défaut (au cas où d'autres essais/checkpoints
# plus lourds y atterrissent), MAIS on autorise explicitement le modèle
# final livré : 9 Mo, largement sous la limite GitHub (100 Mo), utile pour
# l'équipe et pour Docker.
models/*
!models/.gitkeep
!models/modele_eco_sort.h5

# --- Fichiers d'environnement / secrets ---
.env
*.env.local

# --- IDE / éditeurs ---
.vscode/
.idea/
*.swp

# --- Système ---
.DS_Store
Thumbs.db

# --- Docker (volumes locaux éventuels) ---
docker-data/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Tests / couverture ---
.pytest_cache/
.coverage
htmlcov/
